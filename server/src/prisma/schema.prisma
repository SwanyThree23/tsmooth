// T-Smooth Productions - Prisma Schema with Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String
  name            String
  role            String          @default("user")
  avatar          String?
  stripeAccountId String?
  createdAt       DateTime        @default(now())
  projects        Project[]
  clients         Client[]
  invoices        Invoice[]
  videos          Video[]
  tasks           Task[]
  notes           Note[]
  tipsReceived    Tip[]           @relation("TipReceiver")
  tipsSent        Tip[]           @relation("TipSender")
  chatMessages    ChatMessage[]
  watchParties    WatchPartyMember[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String
  status      String
  priority    String
  budget      Float
  progress    Int
  deadline    DateTime
  description String?
  tags        String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  company      String?
  industry     String?
  totalPaid    Float    @default(0)
  projectCount Int      @default(0)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  client        String
  project       String?
  amount        Float
  status        String
  dueDate       DateTime
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  embedUrl    String
  thumbnail   String?
  source      String?
  category    String?
  tags        String[]
  views       Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String
  status      String
  dueDate     DateTime?
  completed   Boolean   @default(false)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tip {
  id              String   @id @default(cuid())
  amount          Float
  currency        String   @default("usd")
  message         String?
  stripePaymentId String?  @unique
  status          String   @default("pending")
  senderId        String
  receiverId      String
  sender          User     @relation("TipSender", fields: [senderId], references: [id])
  receiver        User     @relation("TipReceiver", fields: [receiverId], references: [id])
  createdAt       DateTime @default(now())
}

model ChatMessage {
  id          String   @id @default(cuid())
  roomId      String
  content     String
  messageType String   @default("text")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([roomId, createdAt])
}

model WatchParty {
  id           String             @id @default(cuid())
  title        String
  hostId       String
  videoUrl     String
  videoState   Json               @default("{\"playing\": false, \"currentTime\": 0}")
  roomCode     String             @unique
  isLive       Boolean            @default(false)
  maxMembers   Int                @default(20)
  rtmpKey      String?
  createdAt    DateTime           @default(now())
  members      WatchPartyMember[]
  chatMessages ChatMessage[]      @ignore
}

model WatchPartyMember {
  id           String     @id @default(cuid())
  watchPartyId String
  userId       String
  role         String     @default("viewer")
  liveKitToken String?
  joinedAt     DateTime   @default(now())
  watchParty   WatchParty @relation(fields: [watchPartyId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([watchPartyId, userId])
}
